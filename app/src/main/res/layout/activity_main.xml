<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="6dp">

        <!-- Game Modes -->
        <CheckBox
            android:id="@+id/mode0"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Click Task"
            />

        <CheckBox
            android:id="@+id/mode1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Random Task 1"
            />

        <CheckBox
            android:id="@+id/mode2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Random Task 2"
            />
        <!-- - - - - - -->

        <EditText
            android:id="@+id/roundsInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Round Number"
            android:inputType="number"
            android:layout_marginTop="24dp"
            />

        <EditText
            android:id="@+id/seedInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Seed (leave blank for random)"
            android:inputType="number"
            android:layout_marginTop="8dp"
            />

        <Button
            android:id="@+id/startButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Singleplayer"
            android:layout_marginTop="24dp"
            />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>